    "@vitest/coverage-v8": "^4.0.0",
    "express": "^4.21.0",
    "jsdom": "^25.0.0",
    "oxfmt": "^0.4.0",
    "oxlint": "^0.13.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
