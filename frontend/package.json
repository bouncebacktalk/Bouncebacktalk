    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
