{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
  "lineWidth": 100,
  "indentWidth": 2,
  "useTabs": false,
  "quoteStyle": "single",
  "jsxQuoteStyle": "double",
  "trailingComma": "all",
  "semi": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "frontend/dist/**",
    "backend-nest/dist/**",
    "backend-nest/prisma/migrations/**",
    "*.md"
  ]
}
