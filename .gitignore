# =============================================================================
# Data, not code (per ADR-0090: repo-bloat-protection)
# =============================================================================
# Big files belong on the VM disk, not in git. Forgejo enforces a 1 GB (Pro) /
# 5 GB (Business) total repo-size quota; pushes that would exceed it are
# rejected. Keep datasets, uploads, and generated blobs out of git so the
# quota only counts what's actually code. Use git-lfs if you genuinely need a
# large file under version control.
data/
uploads/
.cache/

# Common dataset / binary blob extensions
*.parquet
*.feather
*.arrow
*.pkl
*.npy
*.npz
*.h5
*.hdf5
*.sqlite
*.sqlite3
*.db
*.dump

# Archives (don't commit a tarball; commit its source layout instead)
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# Large source-art / video (small media still fine in /public/)
*.psd
*.ai
*.mov
*.mp4
*.mkv

